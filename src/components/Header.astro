---
// src/components/Header.astro
---

<header id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-300 py-6">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-10 h-10 bg-accent rounded-lg flex items-center justify-center transition-transform group-hover:scale-110 p-0.5">
        <svg class="w-full h-full" viewBox="0 0 128 128" fill="none">
          <!-- Curly Braces (White for contrast on purple accent) -->
          <path d="M25 35c-4 0-7 3-7 7v15c0 4-2 6-5 6 3 0 5 2 5 6v15c0 4 3 7 7 7" stroke="white" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M103 35c4 0 7 3 7 7v15c0 4 2 6 5 6-3 0-5 2-5 6v15c0 4-3 7-7 7" stroke="white" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
          
          <!-- Green Pixels -->
          <rect x="78" y="38" width="14" height="14" fill="#76FF03"/>
          <rect x="91" y="31" width="8" height="8" fill="#76FF03"/>
          <rect x="85" y="25" width="5" height="5" fill="#76FF03"/>
          
          <!-- BRZ Text (Interlocking Bold Style) -->
          <g fill="white">
            <path d="M28 45h12c5 0 8 2.5 8 6.5s-2 5.5-5 6c4 0.5 6 3 6 7.5s-3.5 8-9 8H28V45zm5 6v7h6c2.5 0 3.5-1 3.5-3.5S41.5 51 39 51h-6zm0 12v10h7c3 0 4.5-1.5 4.5-5s-1.5-5-4.5-5h-7z"/>
            <path d="M50 45h11c5 0 8 2.5 8 6.5s-3 6-6 6.5L69 73h-6l-5-10.5h-3V73h-5V45zm5 6v7h5c2.5 0 3.5-1 3.5-3.5S62.5 51 60 51h-5z"/>
            <path d="M71 45h18v5l-12 18h12v5H71v-5l12-18H71v-5z"/>
          </g>
        </svg>
      </div>
      <span class="text-xl font-extrabold tracking-tighter text-white">Broz <span class="text-accent">Studio</span></span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      <a href="#about" class="text-sm font-medium text-gray-400 hover:text-white transition-colors">О нас</a>
      <a href="#process" class="text-sm font-medium text-gray-400 hover:text-white transition-colors">Процесс</a>
      <a href="#pricing" class="text-sm font-medium text-gray-400 hover:text-white transition-colors">Цены</a>
      <a href="#portfolio" class="text-sm font-medium text-gray-400 hover:text-white transition-colors">Кейсы</a>
    </nav>

    <div class="flex items-center gap-4">
      <a href="#contact" class="hidden sm:inline-flex px-6 py-2.5 bg-white text-black text-sm font-bold rounded-button transition-transform hover:scale-105 active:scale-95">
        Обсудить проект
      </a>
      <button class="md:hidden text-white">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></button>
    </div>
  </div>
</header>

<script is:inline>
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header.classList.add('header-scrolled');
      header.classList.remove('py-6');
      header.classList.add('py-4');
    } else {
      header.classList.remove('header-scrolled');
      header.classList.add('py-6');
      header.classList.remove('py-4');
    }
  });
</script>
