---
// src/components/Header.astro
---

<header id="main-header" class="fixed top-6 left-1/2 -translate-x-1/2 w-[95%] max-w-7xl z-50 transition-all duration-500 rounded-full border border-transparent">
  <div class="px-8 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <div class="relative w-8 h-8 flex items-center justify-center">
        <div class="absolute inset-0 border border-accent/40 rotate-45 group-hover:rotate-90 transition-transform duration-500"></div>
        <div class="absolute inset-1 border border-accent/20 -rotate-12 group-hover:rotate-0 transition-transform duration-700"></div>
        <span class="font-heading text-xl font-bold text-white group-hover:text-accent transition-colors">B</span>
      </div>
      <span class="text-lg font-heading tracking-widest text-white uppercase font-bold">Broz <span class="text-accent italic font-normal">Agency</span></span>
    </a>

    <nav class="hidden md:flex items-center gap-10">
      {[
        { label: 'О нас', id: 'about' },
        { label: 'Метод', id: 'process' },
        { label: 'Цены', id: 'pricing' },
        { label: 'Кейсы', id: 'portfolio' }
      ].map((item) => (
        <a 
          href={`#${item.id}`} 
          class="text-[10px] uppercase tracking-[0.3em] font-bold text-slate-400 hover:text-accent transition-all relative group"
        >
          {item.label}
          <span class="absolute -bottom-1 left-0 w-0 h-[1px] bg-accent transition-all group-hover:w-full"></span>
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-6">
      <a href="#contact" class="hidden sm:inline-flex px-6 py-2 bg-accent text-white text-[10px] uppercase tracking-widest font-bold rounded-button hover:shadow-[0_0_20px_-5px_var(--color-accent)] transition-all active:scale-95">
        Связаться
      </a>
      <button class="md:hidden text-white p-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

<script is:inline>
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      header.classList.add('bg-background/60', 'backdrop-blur-xl', 'border-border-primary', 'top-4');
    } else {
      header.classList.remove('bg-background/60', 'backdrop-blur-xl', 'border-border-primary', 'top-4');
    }
  });
</script>
