---
// src/components/About.astro
---

<section id="about" class="py-32 px-6 bg-background relative overflow-hidden">
  <!-- Sovereign Glow -->
  <div class="absolute top-1/2 left-0 -translate-y-1/2 w-[600px] h-[600px] bg-accent/5 rounded-full blur-[140px] -z-10"></div>

  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      <div>
        <h2 class="text-4xl md:text-6xl font-heading mb-10 tracking-tight italic">
          Почему <span class="text-accent not-italic font-bold">Мы?</span>
        </h2>
        
        <p class="text-slate-400 text-lg leading-relaxed mb-12 font-light max-w-xl italic">
          «Мы не просто пишем код — мы строим цифровые активы, которые принадлежат вам.»
        </p>
        
        <div class="space-y-8">
          <div class="reveal flex gap-6 p-8 glass-panel rounded-container group">
            <div class="w-14 h-14 bg-accent/5 rounded-button flex items-center justify-center border border-accent/20 shrink-0 group-hover:border-accent/50 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
              </svg>
            </div>
            <div>
              <h3 class="text-white font-heading text-xl mb-2 italic">Бизнес-интеллект</h3>
              <p class="text-slate-500 text-sm font-light">Специалисты с образованием в экономике и IT. Мы строим решения, которые окупаются, а не просто потребляют ресурсы.</p>
            </div>
          </div>

          <div class="reveal flex gap-6 p-8 glass-panel rounded-container group" style="transition-delay: 100ms">
            <div class="w-14 h-14 bg-accent/5 rounded-button flex items-center justify-center border border-accent/20 shrink-0 group-hover:border-accent/50 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <h3 class="text-white font-heading text-xl mb-2 italic">Экспертиза сообщества</h3>
              <p class="text-slate-500 text-sm font-light">Организаторы сообщества разработчиков @flutterflow_rus. Развиваем культуру быстрой и качественной разработки в СНГ.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="relative group h-[500px]">
        <!-- Option 3: Bento Blueprint Visualizer -->
        <div class="grid grid-cols-2 grid-rows-2 gap-4 h-full">
          <!-- Fast Module -->
          <div class="glass-panel rounded-container p-6 flex flex-col justify-between overflow-hidden relative group/item">
            <div class="absolute top-0 right-0 p-2 opacity-10 group-hover/item:opacity-30 transition-opacity">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
            <span class="text-[9px] font-mono text-slate-500 uppercase tracking-widest">Velocity</span>
            <h3 class="text-3xl font-heading font-black text-white italic">Быстро.</h3>
          </div>

          <!-- Good Module -->
          <div class="glass-panel rounded-container p-6 flex flex-col justify-between overflow-hidden relative group/item">
            <div class="absolute top-0 right-0 p-2 opacity-10 group-hover/item:opacity-30 transition-opacity">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <span class="text-[9px] font-mono text-slate-500 uppercase tracking-widest">Quality</span>
            <h3 class="text-3xl font-heading font-black text-white italic">Хорошо.</h3>
          </div>

          <!-- Flexible Module (Main Area) -->
          <div class="col-span-2 glass-panel rounded-container p-8 flex flex-col justify-between relative overflow-hidden group/flex">
            <!-- Animated Blueprint Background -->
            <div class="absolute inset-0 bg-[linear-gradient(to_right,#0ea5e9_1px,transparent_1px),linear-gradient(to_bottom,#0ea5e9_1px,transparent_1px)] bg-[size:20px_20px] opacity-[0.03] group-hover/flex:opacity-[0.08] transition-opacity"></div>
            
            <div class="relative z-10 flex justify-between items-start">
              <div>
                <span class="text-[9px] font-mono text-accent uppercase tracking-widest block mb-1">Architecture</span>
                <h3 class="text-6xl font-heading font-black text-accent italic tracking-tighter drop-shadow-[0_0_15px_rgba(14,165,233,0.3)]">Гибко.</h3>
              </div>
              <div class="flex flex-col items-end text-[8px] font-mono text-slate-600 gap-1 uppercase tracking-widest">
                <span>Deprecated: Fixed Scope</span>
                <span class="text-slate-400">Status: Autonomous</span>
              </div>
            </div>

            <div class="relative z-10 mt-auto flex items-center justify-between">
              <p class="text-[10px] text-slate-500 max-w-[200px] leading-relaxed font-light">
                Мы адаптируемся к изменениям рынка быстрее, чем вы успеете обновить бэклог.
              </p>
              <!-- Small visual icon for flexibility -->
              <div class="w-10 h-10 border border-accent/20 rounded flex items-center justify-center">
                <div class="w-4 h-4 border border-accent rounded-sm rotate-45 animate-spin [animation-duration:5s]"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Professional Badge -->
        <div class="absolute -bottom-6 -right-6 p-6 bg-surface border border-accent/20 rounded-container shadow-2xl backdrop-blur-md reveal" style="transition-delay: 300ms">
          <div class="flex flex-col gap-1">
             <div class="text-3xl font-heading font-bold text-white tracking-tighter italic">100%</div>
             <div class="text-[8px] text-slate-500 uppercase tracking-[0.2em] leading-tight font-bold">Ownership of<br/>the Outcome</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
