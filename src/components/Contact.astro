---
// src/components/Contact.astro
---

<section id="contact" class="py-32 px-6 bg-background relative overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-accent/5 rounded-full blur-[100px] -z-10"></div>
  <div class="absolute top-0 left-0 w-[300px] h-[300px] bg-accent/5 rounded-full blur-[80px] -z-10"></div>

  <div class="max-w-4xl mx-auto text-center relative z-10">
    <!-- Availability Indicator -->
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm mb-12 animate-fade-in-down">
      <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse-green"></span>
      <span class="text-[12px] uppercase tracking-widest font-medium text-gray-400">Available for new projects</span>
    </div>

    <h2 class="text-4xl md:text-6xl font-bold mb-8 tracking-tight">
      Let's build something <br class="hidden md:block" /> 
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-glow">extraordinary.</span>
    </h2>

    <p class="text-gray-400 text-lg md:text-xl max-w-2xl mx-auto mb-16 leading-relaxed">
      Готовы автоматизировать процессы или запустить новый продукт? <br class="hidden md:block" /> 
      Выберите удобный способ связи.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a 
        href="https://t.me/brozaurus" 
        target="_blank"
        rel="noopener noreferrer"
        class="w-full sm:w-auto px-10 py-5 bg-surface text-white font-bold rounded-button border border-border-primary hover:border-accent/50 transition-all hover:scale-105 active:scale-95 flex items-center justify-center gap-2"
      >
        <span>Telegram</span>
      </a>
      
      <a 
        href="https://wa.me/5548992012727" 
        target="_blank"
        rel="noopener noreferrer"
        class="w-full sm:w-auto px-10 py-5 bg-surface text-white font-bold rounded-button border border-border-primary hover:border-accent/50 transition-all hover:scale-105 active:scale-95 flex items-center justify-center gap-2"
      >
        <span>WhatsApp</span>
      </a>
    </div>

    <!-- Additional subtle text -->
    <p class="mt-12 text-gray-500 text-sm uppercase tracking-[0.2em] font-medium">
      Average response time: &lt; 2 hours
    </p>
  </div>
</section>
