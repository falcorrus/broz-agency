---
// src/components/Portfolio.astro

const projects = [
  {
    title: "CoinLover",
    description: "Универсальный трекер личных финансов с глубокой аналитикой в реальном времени.",
    category: "Мобильное приложение",
    image: "https://images.unsplash.com/photo-1563986768609-322da13575f3?auto=format&fit=crop&q=80&w=800",
    link: "https://coinlover.ru/landing"
  },
  {
    title: "Baonline",
    description: "Масштабируемый сервис для международного сообщества релокантов. Магазины, автосбор новостей.",
    category: "Веб-платформа",
    image: "https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&q=80&w=800",
    link: "https://bao.reloto.ru"
  },
  {
    title: "NewAddress",
    description: "MVP-витрина и система управления недвижимостью для кратковременной аренды.",
    category: "Веб-приложение",
    image: "https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&q=80&w=800",
    link: "http://reloto.ru/na"
  },
  {
    title: "RAG Online",
    description: "AI-автоответчик для автоматизации малого бизнеса и коммуникаций в «одну кнопку».",
    category: "Веб-приложение",
    image: "https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&q=80&w=800",
    link: "https://rag.reloto.ru"
  },
  {
    title: "RAG Search",
    description: "Интеллектуальный контекстный поиск по вашим файлам и документам на базе AI.",
    category: "Веб-приложение",
    image: "https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&q=80&w=800",
    link: "https://search.reloto.ru/"
  }
];
---

<section id="portfolio" class="py-24 px-6 bg-background">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row items-end justify-between mb-16 gap-6">
      <div class="max-w-2xl">
        <h2 class="text-3xl md:text-5xl font-bold mb-6 tracking-tight italic uppercase">
          <span class="text-accent block text-sm tracking-[0.3em] font-bold not-italic mb-2">Экспертиза в действии</span>
          Избранные кейсы
        </h2>
        <p class="text-gray-400 text-lg leading-relaxed">
          Проекты, которые решают реальные боли бизнеса через автоматизацию, <br class="hidden md:block" /> 
          чистый UX и масштабируемую архитектуру.
        </p>
      </div>
      <div class="pb-1">
        <div class="w-32 h-[1px] bg-gradient-to-r from-accent to-transparent"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((project, index) => (
        <a 
          href={project.link} 
          target="_blank"
          class="reveal group block bg-surface border border-border-primary rounded-container overflow-hidden hover:border-accent/50 transition-all duration-500 hover:-translate-y-2 shadow-2xl"
          style={`transition-delay: ${index * 100}ms`}
        >
          <div class="relative aspect-[4/3] overflow-hidden">
            <img 
              src={project.image} 
              alt={project.title}
              class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-surface via-transparent to-transparent opacity-60"></div>
            
            <!-- Category Badge overlay -->
            <div class="absolute top-4 left-4">
              <span class="bg-background/80 backdrop-blur-md text-accent text-[10px] uppercase tracking-widest font-bold px-3 py-1.5 rounded-full border border-accent/20">
                {project.category}
              </span>
            </div>
          </div>
          
          <div class="p-8">
            <h3 class="text-2xl font-bold mb-3 group-hover:text-accent transition-colors">
              {project.title}
            </h3>
            
            <p class="text-gray-400 text-sm leading-relaxed mb-6">
              {project.description}
            </p>
            
            <div class="flex items-center gap-2 text-accent text-sm font-bold uppercase tracking-widest overflow-hidden">
              <span class="translate-x-0 group-hover:translate-x-1 transition-transform duration-300">Подробнее</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 -translate-x-1 group-hover:translate-x-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
