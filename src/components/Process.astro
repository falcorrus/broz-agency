---
// src/components/Process.astro
import ProcessCards from './ProcessCards';
---

<section id="process" class="py-32 px-6 bg-background relative overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-24">
      <h2 class="text-4xl md:text-6xl font-heading mb-6 tracking-tight italic">
        Ваш путь <span class="text-accent not-italic font-bold">к продукту.</span>
      </h2>
      <p class="text-slate-400 text-lg max-w-3xl mx-auto font-light leading-relaxed">
        Прозрачный процесс от первого звонка до работающей системы. <br class="hidden md:block" /> 
        Максимальная скорость без потери качества.
      </p>
    </div>

    <ProcessCards client:load />
  </div>
</section>
