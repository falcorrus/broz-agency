---
// src/components/Pricing.astro

const plans = [
  {
    name: "Старт MVP",
    price: "$500",
    description: "Быстрая проверка гипотезы. Прототип, UI/UX и первая работающая версия за 48 часов.",
    features: [
      "Проектирование логики",
      "UI/UX Дизайн (Figma/AI)",
      "Разработка MVP (Astro/React)",
      "Базовая SEO-оптимизация",
      "Деплой на ваш сервер"
    ],
    highlight: false,
    cta: "Заказать MVP"
  },
  {
    name: "Полный продукт",
    price: "$4500",
    description: "Полноценный продукт с масштабируемой архитектурой и глубокой проработкой UX.",
    features: [
      "Все из MVP Start",
      "Backend разработка (Supabase/Node)",
      "Интеграция AI-моделей",
      "Система аналитики",
      "Поддержка 1 месяц"
    ],
    highlight: true,
    cta: "Запустить продукт"
  },
  {
    name: "AI-автоматизация",
    price: "Custom",
    description: "Автоматизация сложных бизнес-процессов с использованием LLM и кастомных RAG-систем.",
    features: [
      "Аудит процессов",
      "Сценарии n8n / Python",
      "RAG (Поиск по документам)",
      "AI-агенты для Telegram/Web",
      "Интеграция с CRM/API"
    ],
    highlight: false,
    cta: "Обсудить проект"
  }
];
---

<section id="pricing" class="py-32 px-6 bg-background relative overflow-hidden">
  <div class="max-w-7xl mx-auto relative z-10">
    <div class="text-center mb-24">
      <h2 class="text-4xl md:text-6xl font-heading mb-6 tracking-tight italic">
        Прозрачная <span class="text-accent not-italic font-bold">Стоимость.</span>
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto font-light">
        Все виды договоров. Все виды платежей. <br class="hidden md:block" /> 
        Мы фокусируемся на результате.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
      {plans.map((plan, index) => (
        <div 
          class:list={[
            "reveal group relative p-10 glass-panel rounded-container flex flex-col transition-all duration-500",
            { "border-accent/40 shadow-[0_0_50px_-12px_rgba(14,165,233,0.3)] scale-105 z-10": plan.highlight }
          ]}
          style={`transition-delay: ${index * 150}ms`}
        >
          {plan.highlight && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-accent text-white text-[9px] font-bold uppercase tracking-[0.2em] px-4 py-1.5 rounded-full">
              Recommended
            </div>
          )}
          
          <div class="mb-10">
            <span class="text-[10px] font-mono text-slate-500 uppercase tracking-widest block mb-2">Module {index + 1}</span>
            <h3 class="text-2xl font-heading font-bold mb-4 text-white group-hover:text-accent transition-colors italic">{plan.name}</h3>
            <div class="flex items-baseline gap-2 mb-6">
              <span class="text-5xl font-heading font-black text-white italic tracking-tighter">{plan.price}</span>
              {plan.price !== "Custom" && <span class="text-slate-500 text-[10px] font-mono uppercase tracking-widest">/ asset</span>}
            </div>
            <p class="text-slate-500 text-sm leading-relaxed font-light">{plan.description}</p>
          </div>

          <ul class="space-y-4 mb-12 flex-1">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3 text-xs text-slate-400 font-light group-hover:text-slate-300 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent/60 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          <a 
            href="#contact" 
            class:list={[
              "w-full py-4 text-[10px] uppercase tracking-[0.2em] font-bold rounded-button text-center transition-all active:scale-95",
              plan.highlight 
                ? "bg-accent text-white shadow-[0_0_20px_rgba(14,165,233,0.4)]" 
                : "bg-white/5 text-white border border-border-primary hover:border-accent/50 hover:bg-accent/5"
            ]}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
