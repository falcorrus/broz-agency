---
// src/components/Hero.astro
import WaveText from './WaveText';
---

<section class="relative min-h-[90vh] flex flex-col items-center justify-center px-6 overflow-hidden pt-20">
  <!-- Grid Background -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#1e293b_1px,transparent_1px),linear-gradient(to_bottom,#1e293b_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-20"></div>
    
    <!-- Subtle Glows -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] bg-accent/5 rounded-full blur-[120px]"></div>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto text-center">
    <!-- Authority Badge -->
    <div class="reveal inline-flex items-center gap-2 px-3 py-1 rounded-full border border-accent/20 bg-accent/5 mb-8 animate-fade-in-down">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-success"></span>
      </span>
      <span class="text-[10px] uppercase tracking-[0.2em] font-bold text-accent">Engineering v2.0</span>
    </div>

    <h1 class="text-6xl md:text-8xl lg:text-9xl font-heading font-medium tracking-tight mb-8 leading-[0.9] italic">
      Превращаем задачи <br />
      <WaveText client:load texts={["в прибыль.", "в активы.", "в результат."]} />
    </h1>

    <p class="text-lg md:text-2xl text-slate-400 max-w-3xl mx-auto mb-12 leading-relaxed font-light">
      Создаем IT-решения, которые экономят ресурсы <br class="hidden md:block" /> 
      и масштабируют ваш бизнес.
    </p>

    <div class="reveal flex flex-col sm:flex-row items-center justify-center gap-6" style="transition-delay: 200ms">
      <a 
        href="#contact" 
        class="group relative px-10 py-4 bg-accent text-white font-medium rounded-button overflow-hidden transition-all hover:shadow-[0_0_30px_-5px_var(--color-accent)] active:scale-95"
      >
        Запустить процесс
      </a>
      <a 
        href="#portfolio" 
        class="px-10 py-4 bg-transparent text-slate-300 font-medium rounded-button border border-border-primary hover:bg-surface/50 hover:text-white transition-all active:scale-95"
      >
        Решения
      </a>
    </div>
  </div>
  
  <!-- Scroll Indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-4 text-slate-500 opacity-50">
    <div class="w-[1px] h-12 bg-gradient-to-b from-accent to-transparent"></div>
  </div>
</section>
