---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Portfolio from '../components/Portfolio.astro';
import Contact from '../components/Contact.astro';
import { TrustBadge } from '../components/TrustBadge';
import MagicSlider from '../components/MagicSlider';
import Process from '../components/Process.astro';
import About from '../components/About.astro';
import Pricing from '../components/Pricing.astro';
---

<Layout title="broz.agency | Превращаем задачи в прибыль">
  <main class="relative">
    <section class="reveal">
      <Hero />
    </section>
    
    <section class="reveal">
      <MagicSlider client:load />
    </section>
    
    <section id="process" class="reveal">
      <Process />
    </section>
    
    <section id="about" class="reveal">
      <About />
    </section>
    
    <section id="pricing" class="reveal">
      <Pricing />
    </section>
    
    <section id="portfolio" class="reveal">
      <Portfolio />
    </section>
    
    <TrustBadge client:load />
    
    <section id="contact" class="reveal">
      <Contact />
    </section>
  </main>
</Layout>
